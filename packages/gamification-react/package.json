{
  "name": "@heybray/gamification-react",
  "version": "1.2.3",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybray-labs/bray-platform.git",
    "directory": "packages/gamification-react"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./points/*": {
      "types": "./dist/points/*.d.ts",
      "default": "./dist/points/*.js"
    },
    "./teams/*": {
      "types": "./dist/teams/*.d.ts",
      "default": "./dist/teams/*.js"
    },
    "./teams/star-map-types": {
      "types": "./dist/teams/star-map-types.d.ts",
      "default": "./dist/teams/star-map-types.js"
    },
    "./teams/star-map-utils": {
      "types": "./dist/teams/star-map-utils.d.ts",
      "default": "./dist/teams/star-map-utils.js"
    },
    "./teams/star-map-paths": {
      "types": "./dist/teams/star-map-paths.d.ts",
      "default": "./dist/teams/star-map-paths.js"
    },
    "./teams/drawer-pink-styles": {
      "types": "./dist/teams/drawer-pink-styles.d.ts",
      "default": "./dist/teams/drawer-pink-styles.js"
    },
    "./reveal/*": {
      "types": "./dist/reveal/*.d.ts",
      "default": "./dist/reveal/*.js"
    },
    "./reveal/stages": {
      "types": "./dist/reveal/stages.d.ts",
      "default": "./dist/reveal/stages.js"
    },
    "./reveal/reveal-hooks": {
      "types": "./dist/reveal/reveal-hooks.d.ts",
      "default": "./dist/reveal/reveal-hooks.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@heybray/gamification": "^1.1.3",
    "@heybray/react": "^1.2.4",
    "@heybray/ui": "^1.2.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.60.5",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "glob": "^13.0.6",
    "happy-dom": "^17.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
