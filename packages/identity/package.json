{
  "name": "@heybray/identity",
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "dependencies": {
    "@heybray/server-kit": "^1.3.0",
    "@node-saml/node-saml": "^5.1.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "openid-client": "^6.8.4",
    "selfsigned": "^5.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.16.11",
    "@types/selfsigned": "^2.0.4",
    "typescript": "^5.6.3"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybray-labs/bray-platform.git",
    "directory": "packages/identity"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ]
}
