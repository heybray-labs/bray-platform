{
  "name": "@heybray/react",
  "version": "1.3.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybray-labs/bray-platform.git",
    "directory": "packages/react"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "exports": {
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./dist/hooks/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./admin/*": {
      "types": "./dist/admin/*.d.ts",
      "default": "./dist/admin/*.js"
    },
    "./pages/*": {
      "types": "./dist/pages/*.d.ts",
      "default": "./dist/pages/*.js"
    },
    "./classifications/*": {
      "types": "./dist/classifications/*.d.ts",
      "default": "./dist/classifications/*.js"
    },
    "./config": {
      "types": "./dist/config/app-config.d.ts",
      "default": "./dist/config/app-config.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./extensions/*": {
      "types": "./dist/extensions/*.d.ts",
      "default": "./dist/extensions/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heybray/identity": "^1.1.0",
    "@heybray/taxonomy": "^1.0.1",
    "@heybray/ui": "^1.2.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.60.5",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "glob": "^13.0.6",
    "happy-dom": "^18.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
